#!/usr/bin/env bash
set -euo pipefail

# README maintenance is per-CARD, not per-commit (see CLAUDE.md "Working method"
# rule 3): the README is a user-facing public-API document, updated when a card
# changes the public API / coverage / a salient feature, and consolidated every
# ~10 cards. This hook therefore does NOT force a README.md change on every
# commit — that mechanical rule turned the README into a per-commit progress log.

# If any GitHub Actions workflow is staged, lint it before it can land. Mirrors
# the `bombay-actionlint` flake check, run eagerly here so a broken workflow is
# caught at commit time rather than only by `nix flake check` / CI. Runs only
# when a workflow file is actually touched, so non-CI commits pay nothing.
if git diff --cached --name-only --diff-filter=ACMR \
  | grep -qE '^\.github/workflows/.*\.ya?ml$'; then
  echo "pre-commit: GitHub Actions workflow changed — running actionlint..."
  nix run nixpkgs#actionlint -- .github/workflows/*.yml
  echo "pre-commit: actionlint passed."
fi
