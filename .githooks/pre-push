#!/usr/bin/env bash
set -euo pipefail

# The single CI gate must pass before any push (CLAUDE.md: "nix flake check is
# the single gate" — build + clippy + fmt + audit + deny + tests).
#
# NOTE: the `clippy` check is intentionally RED while the vendored kameo (~19k
# LOC) is brought up to bombay's god-level lint bar (cards M1/M7). Until then
# this hook blocks pushes — bypass a specific push with `git push --no-verify`.
echo "pre-push: running nix flake check (the single gate)..."
nix flake check
echo "pre-push: nix flake check passed."
